# Supabase (필수: Supabase 프로젝트 설정에서 확인)
NEXT_PUBLIC_SUPABASE_URL="your_supabase_project_url"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_supabase_anon_key"

# FastAPI AI 엔진 (A* / PPO 경로 최적화)
NEXT_PUBLIC_AI_ENGINE_URL="http://localhost:8000"

# RTD 연동 (통합 실행 시에만 활성화, 기본 false)
NEXT_PUBLIC_RTD_ENABLED="false"
NEXT_PUBLIC_RTD_API_URL="http://localhost:3000/api"
