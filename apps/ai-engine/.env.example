# Supabase 연결 정보 (service_role_key: RLS 우회, 서버 전용)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# PPO 모델 경로 (학습 후 생성됨)
MODEL_PATH=trained_models/ppo_route.zip

# CORS 허용 오리진 (JSON 배열 문자열)
CORS_ORIGINS=["http://localhost:3000"]

# FastAPI 서버 포트
PORT=8000
