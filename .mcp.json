{
	"mcpServers": {
		"shadcn": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"shadcn@latest",
				"mcp"
			],
			"sequential-thinking": {
				"command": "npx",
				"args": [
					"-y",
					"@modelcontextprotocol/server-sequential-thinking"
				]
			}
		},
		"task-master-ai": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"task-master-ai"
			],
			"env": {
				"TASK_MASTER_TOOLS": "core",
				"ANTHROPIC_API_KEY": "YOUR_ANTHROPIC_API_KEY_HERE"
			}
		}
	}
}
