{
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:rtd": "turbo run dev --filter=rtd",
    "dev:mcs": "turbo run dev --filter=mcs",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "turbo": "^2.5.0"
  },
  "packageManager": "npm@11.11.0"
}
